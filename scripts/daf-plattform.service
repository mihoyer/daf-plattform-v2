[Unit]
Description=DaF Sprachdiagnostik Plattform
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/daf-plattform
EnvironmentFile=/var/www/daf-plattform/.env
ExecStart=/var/www/daf-plattform/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
